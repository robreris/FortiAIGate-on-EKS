    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "BedrockConverseAccess",
            "Effect": "Allow",
            "Action": "bedrock:InvokeModel",
            "Resource": [
                "arn:aws:bedrock:*:123456789012:inference-profile/us.amazon.nova-lite-v1:0",
